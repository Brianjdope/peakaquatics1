# ── Google Calendar ──────────────────────────────────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
# Comma-separated calendar IDs (use "primary" for your main calendar)
# Find IDs in Google Calendar Settings → specific calendar → "Calendar ID"
GOOGLE_CALENDAR_IDS=primary

# ── Notion ────────────────────────────────────────────────────────────────────
# From notion.so/my-integrations → create integration → Internal Integration Secret
NOTION_TOKEN=secret_xxxxxxxxxxxx
# The database ID from the URL: notion.so/<workspace>/<DATABASE_ID>?v=...
# Comma-separated if you have multiple calendar databases
NOTION_DATABASE_IDS=your_database_id_here

# ── Output ────────────────────────────────────────────────────────────────────
# How many days ahead/behind to fetch (default: 30 past, 90 future)
DAYS_PAST=30
DAYS_FUTURE=90
# Output file path (relative to scripts/)
OUTPUT_FILE=../compiled-calendar.ics
